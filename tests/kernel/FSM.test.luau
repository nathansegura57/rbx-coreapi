suite:Test("OnUpdate: stops firing after mode exits", function(ctx)
	local updateCount = 0
	local fsm = FSM.New({})
	fsm:Mode("idle"):OnUpdate(function(_c, _dt, _f)
		updateCount += 1
	end)
