suite:Test("Switch SingleSwitchPerFrame: latest pending request wins", function(ctx)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Mode("running")
	fsm:Mode("paused")
	fsm:Start("idle")
	fsm:Switch("running")
	fsm:Switch("paused")
	ctx.Mock:Flush()
	ctx:Expect(fsm:Current()):ToBe("paused")
	fsm:Destroy()
end)

suite:Test("Switch passes Reason and Data through transition event", function(ctx)
	local events: { FSM.TransitionEvent } = {}
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Mode("running")
	fsm:OnTransition(function(event)
		table.insert(events, event)
	end)
	fsm:Start("idle")
	fsm:Switch("running", { Immediate = true, Reason = "play", Data = 42 })
	ctx:Expect(events[2].Reason):ToBe("play")
	ctx:Expect(events[2].Data):ToBe(42)
	fsm:Destroy()
end)

