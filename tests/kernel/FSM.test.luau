-- ── FSM.DefaultPolicy ─────────────────────────────────────────────────────────

suite:Test("DefaultPolicy returns correct defaults", function(ctx)
	local policy = FSM.DefaultPolicy()
	ctx:Expect(policy.SingleSwitchPerFrame):ToBe(true)
	ctx:Expect(policy.CancelTasksOnExit):ToBe(true)
	ctx:Expect(policy.ExitOrdering):ToBe("LeafFirst")
	ctx:Expect(policy.Deferral):ToBe("Queue")
	ctx:Expect(policy.Trace):ToBe(false)
end)

suite:Test("DefaultPolicy returns a fresh clone each call", function(ctx)
	local p1 = FSM.DefaultPolicy()
	local p2 = FSM.DefaultPolicy()
	ctx:Expect(p1 ~= p2):ToBe(true)
end)

-- ── FSM.ValidatePolicy ────────────────────────────────────────────────────────

suite:Test("ValidatePolicy: valid policy returns (true, nil)", function(ctx)
	local ok, msg = FSM.ValidatePolicy({
		SingleSwitchPerFrame = false,
		CancelTasksOnExit = true,
		ExitOrdering = "ParentFirst",
		Deferral = "Drop",
		ErrorPolicy = "Swallow",
		Trace = true,
		Tag = "MyFSM",
	})
	ctx:Expect(ok):ToBe(true)
	ctx:Expect(msg):ToBeNil()
end)

suite:Test("ValidatePolicy: unknown key returns false", function(ctx)
	local ok, msg = FSM.ValidatePolicy({ Bogus = true } :: any)
	ctx:Expect(ok):ToBe(false)
	ctx:Expect(msg :: string):ToMatch("unknown policy key")
end)

suite:Test("ValidatePolicy: invalid ExitOrdering returns false", function(ctx)
	local ok, _ = FSM.ValidatePolicy({ ExitOrdering = "Random" } :: any)
	ctx:Expect(ok):ToBe(false)
end)

suite:Test("ValidatePolicy: invalid Deferral returns false", function(ctx)
	local ok, _ = FSM.ValidatePolicy({ Deferral = "Reject" } :: any)
	ctx:Expect(ok):ToBe(false)
end)

suite:Test("ValidatePolicy: non-boolean SingleSwitchPerFrame returns false", function(ctx)
	local ok, _ = FSM.ValidatePolicy({ SingleSwitchPerFrame = "yes" } :: any)
	ctx:Expect(ok):ToBe(false)
end)

suite:Test("ValidatePolicy: non-boolean CancelTasksOnExit returns false", function(ctx)
	local ok, _ = FSM.ValidatePolicy({ CancelTasksOnExit = 1 } :: any)
	ctx:Expect(ok):ToBe(false)
end)

suite:Test("ValidatePolicy: invalid ErrorPolicy returns false", function(ctx)
	local ok, _ = FSM.ValidatePolicy({ ErrorPolicy = "Ignore" } :: any)
	ctx:Expect(ok):ToBe(false)
end)

suite:Test("ValidatePolicy: non-string Tag returns false", function(ctx)
	local ok, _ = FSM.ValidatePolicy({ Tag = 42 } :: any)
	ctx:Expect(ok):ToBe(false)
end)

-- ── FSM.SetTracer ─────────────────────────────────────────────────────────────

suite:Test("SetTracer: non-function throws", function(ctx)
	ctx:Expect(function()
		FSM.SetTracer(42 :: any)
	end):ToThrow("fn must be a function or nil")
end)

suite:Test("SetTracer: tracer receives FSM.Start event", function(ctx)
	local traces = ctx:CaptureTraces(function(setTracer)
		FSM.SetTracer(setTracer)
	end)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Start("idle")
	ctx:Expect(#traces:EventsNamed("FSM.Start")):ToBe(1)
	fsm:Destroy()
end)

suite:Test("SetTracer: tracer receives FSM.Transition event on Switch", function(ctx)
	local traces = ctx:CaptureTraces(function(setTracer)
		FSM.SetTracer(setTracer)
	end)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Mode("running")
	fsm:Start("idle")
	fsm:Switch("running", { Immediate = true })
	ctx:Expect(#traces:EventsNamed("FSM.Transition")):ToBe(1)
	fsm:Destroy()
end)

suite:Test("SetTracer: tracer receives FSM.Destroy event", function(ctx)
	local traces = ctx:CaptureTraces(function(setTracer)
		FSM.SetTracer(setTracer)
	end)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Start("idle")
	fsm:Destroy()
	ctx:Expect(#traces:EventsNamed("FSM.Destroy")):ToBe(1)
end)

suite:Test("SetTracer: tracer errors route through ErrorHandler Trace phase", function(ctx)
	FSM.SetTracer(function(_event)
		error("tracer crash")
	end)
	local capture = ctx:CaptureErrors()
	capture:Install()
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Start("idle")
	ctx:Expect(capture:HasPhase("Trace")):ToBe(true)
	capture:Uninstall()
	fsm:Destroy()
end)

suite:Test("SetTracer nil: clears the tracer", function(ctx)
	local callCount = 0
	FSM.SetTracer(function(_event)
		callCount += 1
	end)
	FSM.SetTracer(nil)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Start("idle")
	ctx:Expect(callCount):ToBe(0)
	fsm:Destroy()
end)

