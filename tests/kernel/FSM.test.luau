-- ── fsm:Switch ────────────────────────────────────────────────────────────────

suite:Test("Switch deferred: transition executes after Flush", function(ctx)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Mode("running")
	fsm:Start("idle")
	fsm:Switch("running")
	ctx:Expect(fsm:Current()):ToBe("idle")
	ctx.Mock:Flush()
	ctx:Expect(fsm:Current()):ToBe("running")
	fsm:Destroy()
end)

suite:Test("Switch immediate: transition executes synchronously", function(ctx)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Mode("running")
	fsm:Start("idle")
	fsm:Switch("running", { Immediate = true })
	ctx:Expect(fsm:Current()):ToBe("running")
	fsm:Destroy()
end)

suite:Test("Switch: no-op when target is already current", function(ctx)
	local events: { FSM.TransitionEvent } = {}
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Start("idle")
	fsm:OnTransition(function(event)
		table.insert(events, event)
	end)
	fsm:Switch("idle", { Immediate = true })
	ctx:Expect(#events):ToBe(0)
	fsm:Destroy()
end)

suite:Test("Switch: unstarted FSM throws", function(ctx)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	ctx:Expect(function()
		fsm:Switch("idle")
	end):ToThrow("has not started")
