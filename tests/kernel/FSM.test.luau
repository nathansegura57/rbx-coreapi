end)

suite:Test("Switch: unregistered mode throws", function(ctx)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Start("idle")
	ctx:Expect(function()
		fsm:Switch("running")
	end):ToThrow("not registered")
