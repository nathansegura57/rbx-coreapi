	fsm:Start("idle")
	fsm:Restore({ ActivePath = { "missing" }, History = { idle = "running" } }, { Immediate = true })
	ctx:Expect(fsm:Current()):ToBe("idle")
	ctx:Expect(fsm:History("idle")):ToBe(nil)
	fsm:Destroy()
end)

suite:Test("Mode TaskGroup cancels pending tasks when mode exits", function(ctx)
	local fsm = FSM.New({})
	local pending = Task.Delay(10)
	fsm:Mode("idle"):Add(pending)
	fsm:Mode("running")
	fsm:Start("idle")
	fsm:Switch("running", { Immediate = true })
	ctx:Expect(pending:IsCancelled()):ToBe(true)
	ctx:Expect(pending:Token():Reason()):ToBe(Task.Reason.ModeExit)
	fsm:Destroy()
end)

