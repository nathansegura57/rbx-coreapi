-- ── Pathological coverage ────────────────────────────────────────────────────

suite:Test("WaitForTransition resumes with the next transition event", function(ctx)
	local fsm = FSM.New({})
	fsm:Mode("idle")
	fsm:Mode("running")
	fsm:Start("idle")
	local event: any = nil
	local thread = coroutine.create(function()
		event = fsm:WaitForTransition()
	end)
	coroutine.resume(thread)
	fsm:Switch("running", { Immediate = true, Reason = "Manual", Data = { Step = 1 } })
	ctx.Mock:Flush()
	ctx:Expect(event.From):ToBe("idle")
	ctx:Expect(event.To):ToBe("running")
	ctx:Expect(event.Reason):ToBe("Manual")
	ctx:Expect(event.Data.Step):ToBe(1)
	ctx:Expect(coroutine.status(thread)):ToBe("dead")
	fsm:Destroy()
end)

suite:Test("Restore ignores snapshots whose leaf is not registered", function(ctx)
	local fsm = FSM.New({})
	fsm:Mode("idle")
